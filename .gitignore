__pycache__/
*.pyc
results/
samples/
*.npz
*.pdf
*.eps
slurm-*.out
core.*
*.log
.DS_Store
scratch_smoke/
results_smoke/
scratch_*/
*_smoke/
multi_island_seed_*.out
staged_mi_seed_*.out
# SLURM array stdout (sbatch --output=%x_%a_%A.out lands in the experiment dir)
sf_taper_sweep_*.out
experiments/**/*_[0-9]*.out

# --- revision reference artifacts: commit small plot data + figures, keep raw arrays out ---
!reference_results/**/plot_data/*.npz
!reference_results/**/figures/*.pdf
!reference_results/**/figures/*.svg
!reference_results/**/snapshots/*.npz
!reference_results/**/residual_particles/*.npz
# switching-growth Figure 6 inputs (kept so the figure regenerates from saved data)
!reference_results/switch/fields_seed0.npz
!reference_results/switch/switch_snapshots_zoom.pdf
# figure-regeneration inputs and reproducibility clouds (kept; seed-0 only)
!reference_results/multi_island/**/fields_ref.npz
!reference_results/multi_island/**/fields_seed0.npz
!reference_results/multi_island/**/clouds/cloud_*_seed0.npz
!reference_results/staged_multi_island/**/fields_ref.npz
!reference_results/staged_multi_island/**/fields_seed0.npz
!reference_results/staged_multi_island/**/clouds/cloud_*_seed0.npz
# refined pp-KS raw clouds are large + regenerable (base clouds kept for the adaptive demo)
reference_results/keller_segel_ldg_pp/clouds_run/refined/
# large raw per-seed intermediates of the multi-island productions are NOT committed
reference_results/multi_island/**/seed_*/
reference_results/multi_island/**/fields_seed[1-9]*.npz
reference_results/staged_multi_island/**/seed_*/
reference_results/staged_multi_island/**/fields_seed[1-9]*.npz
# large LDG N=320 snapshot (regenerable; S_curves keeps the result)
reference_results/keller_segel_ldg_pp/ldg_*/N320/snapshots.npz
# keep small LDG N80/N160 snapshots (figure regeneration); N320 stays ignored above
!reference_results/keller_segel_ldg_pp/ldg_*/N80/snapshots.npz
!reference_results/keller_segel_ldg_pp/ldg_*/N160/snapshots.npz
# particle blow-up metric: keep diag CSVs + summary + README; drop per-run snapshots/logs
reference_results/keller_segel_ldg_pp/particle_blowup_*/Np*/snapshots/
reference_results/keller_segel_ldg_pp/particle_blowup_*/*.log
reference_results/keller_segel_ldg_pp/particle_blowup_*/Np*/run.log
# solver-field sweep: keep diag CSVs + README + compare json; drop snapshots/logs
reference_results/keller_segel_ldg_pp/solver_field_sweep_*/*/snapshots/
reference_results/keller_segel_ldg_pp/solver_field_sweep_*/*.log
reference_results/keller_segel_ldg_pp/solver_field_sweep_*/*/run.log
# sf_taper sweep: keep diag CSVs + taper_sweep_compare.json + figures + plot_data;
# drop the per-run u-snapshots (regenerable; ~13MB) and logs
reference_results/keller_segel_ldg_pp/sf_taper_*/*/snapshots/*.npz
reference_results/keller_segel_ldg_pp/sf_taper_*/*.log
reference_results/keller_segel_ldg_pp/sf_taper_*/*/run.log
# sf_blob sweep (blob-residual solver field): same policy
reference_results/keller_segel_ldg_pp/sf_blob_*/*/snapshots/*.npz
reference_results/keller_segel_ldg_pp/sf_blob_*/*.log
reference_results/keller_segel_ldg_pp/sf_blob_*/*/run.log
# SLURM array stdout for the blob sweep
sf_blob_sweep_*.out
# solver-field t_b sweep: keep diag CSVs + summary + figures + plot_data; drop snapshots/logs
reference_results/keller_segel_ldg_pp/solver_field_tb_*/*/snapshots/*.npz
reference_results/keller_segel_ldg_pp/solver_field_tb_*/*.log
reference_results/keller_segel_ldg_pp/solver_field_tb_*/*/run.log
sf_tb_*.out
